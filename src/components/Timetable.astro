---
import { Image } from "astro:assets";
import angelImage from "../assets/kneipi_engel_transparent.png";
import logoImage from "../assets/kneipi_damour_transparent.png";
import schedule from "../data/schedule.json";

interface TimeSlot {
  time: string;
  event: string;
  subpoints?: string[];
}

const angelSrc = angelImage.src;
---

<div class="w-full px-4 sm:px-6 lg:px-8 py-10 max-w-5xl mx-auto">
  <div class="flex justify-center mb-8">
    <Image
      src={logoImage}
      alt="Kneipenchor d'Amour"
      class="w-full max-w-xl sm:max-w-2xl h-auto"
    />
  </div>

  <div id="schedule-list" data-angel-src={angelSrc} class="flex flex-col">
    {
      schedule.map((slot) => (
        <div
          data-time={slot.time}
          class="flex items-center gap-2 sm:gap-8 border-b border-gray-200 hover:bg-gray-50 transition-colors py-5 sm:py-8 min-h-[7.5rem] sm:min-h-[8.5rem]"
        >
          {/* Left angel - mirrored */}
          <div class="flex-shrink-0 w-14 sm:w-28 md:w-32 lg:w-36 flex justify-center overflow-visible">
            <img
              src={angelSrc}
              alt=""
              class="angel-left hidden w-32 sm:w-full h-auto scale-x-[-1]"
            />
          </div>

          {/* Time */}
          <div class="flex-shrink-0 w-14 sm:w-24 font-semibold text-gray-900 text-base sm:text-2xl lg:text-3xl text-right">
            {slot.time}
          </div>

          {/* Event */}
          <div class="flex-1 min-w-0 text-gray-700 text-base sm:text-xl lg:text-2xl leading-snug">
            <div class="font-medium">{slot.event}</div>
            {slot.subpoints && (
              <ul class="text-xs sm:text-base lg:text-lg text-gray-500 space-y-1 mt-2 ml-4">
                {slot.subpoints.map((point) => (
                  <li class="list-disc">{point}</li>
                ))}
              </ul>
            )}
          </div>

          {/* Right angel */}
          <div class="flex-shrink-0 w-14 sm:w-28 md:w-32 lg:w-36 flex justify-center overflow-visible">
            <img
              src={angelSrc}
              alt=""
              class="angel-right hidden w-32 sm:w-full h-auto"
            />
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  function updateIndicator() {
    const now = new Date();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();

    const rows = document.querySelectorAll<HTMLElement>("[data-time]");
    let activeRow: HTMLElement | null = null;

    rows.forEach((row) => {
      const [h, m] = row.dataset.time!.split(":").map(Number);
      const rowMinutes = h * 60 + m;
      if (rowMinutes <= currentMinutes) {
        activeRow = row;
      }
    });

    // Hide all indicators
    document.querySelectorAll(".angel-left, .angel-right").forEach((el) => {
      el.classList.add("hidden");
    });

    // Show both angels on active row
    if (activeRow) {
      (activeRow as HTMLElement)
        .querySelector(".angel-left")
        ?.classList.remove("hidden");
      (activeRow as HTMLElement)
        .querySelector(".angel-right")
        ?.classList.remove("hidden");
    }
  }

  updateIndicator();
  setInterval(updateIndicator, 60_000);
</script>
