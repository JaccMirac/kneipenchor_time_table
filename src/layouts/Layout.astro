---
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const basePath = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Kneipenchor Timetable</title>
  </head>
  <body class="bg-gray-50">
    <main class="min-h-screen">
      <slot />
    </main>
    <footer class="px-4 sm:px-6 py-6 border-t border-gray-200 bg-white">
      <div
        class="max-w-5xl mx-auto flex items-center justify-center gap-6 text-sm text-gray-700"
      >
        <a href={`${basePath}impressum/`} class="hover:text-gray-900 underline"
          >Impressum</a
        >
        <a
          href={`${basePath}datenschutz/`}
          class="hover:text-gray-900 underline">Datenschutzerklärung</a
        >
      </div>
    </footer>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
  }
</style>
